{
  "name": "vulnerable-demo-app",
  "version": "1.0.0",
  "description": "Intentionally vulnerable Node.js app to test the secure CI/CD pipeline",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "lint": "eslint . --ext .js --ignore-pattern node_modules/ --env es2021,node --parser-options ecmaVersion:2021",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "express": "4.17.1",
    "mysql2": "2.3.0",
    "node-serialize": "0.0.4",
    "jsonwebtoken": "8.5.1",
    "lodash": "4.17.4"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "supertest": "^6.3.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "app.js",
      "src/**/*.js"
    ],
    "coverageReporters": ["lcov", "text", "json-summary"],
    "coverageThreshold": {
      "global": {
        "lines": 80
      }
    }
  }
}
